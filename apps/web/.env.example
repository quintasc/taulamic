# Proxy API (opcional)
# TAULAMIC_API_ORIGIN=http://localhost:3000

# Sentry (opcional). Sin DSN no se envían eventos.
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Subida de source maps (solo CI/producción con token)
# SENTRY_ORG=tu-org
# SENTRY_PROJECT=taulamic-web
# SENTRY_AUTH_TOKEN=

# Playwright (opcional)
# PLAYWRIGHT_BASE_URL=http://localhost:3001
# PLAYWRIGHT_API_HEALTH_URL=http://localhost:3000/api/docs
