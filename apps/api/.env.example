# API local — copiar a `.env` si necesitas overrides
# PORT=3000

# Motor de distribucion: v1 (CP-SAT, por defecto) o v0 (greedy piloto).
# Los e2e (`npm run test:e2e`) usan el mismo valor; no lo fuerzan a v0.
# DISTRIBUTION_ENGINE=v1

# Sentry (opcional). Sin DSN no se envían eventos.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
